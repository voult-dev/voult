<% layout('layout/boilerplate.ejs') %>

<div class="settings-page">
  <div class="settings-container">
    <h1 class="settings-title">Settings</h1>
    <p class="settings-subtitle">Manage your profile, email, password, and account.</p>

    <!-- Profile -->
    <section class="settings-section card">
      <h2 class="section-title">Profile</h2>
      <form action="/settings" method="post" class="settings-form">
      <input type="hidden" name="_csrf" value="<%=csrfToken %>">
        <% if (user.avatar) { %>
          <div class="form-group avatar-group">
            <img src="<%= user.avatar %>" alt="Avatar" class="settings-avatar" />
          </div>
        <% } %>
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" name="name" id="name" value="<%= user.name %>" class="form-control" required />
        </div>
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" name="username" id="username" value="<%= user.username || '' %>" class="form-control" placeholder="Optional" />
        </div>
        <button type="submit" class="btn-primary">Save profile</button>
      </form>
    </section>

    <!-- Email -->
    <section class="settings-section card">
      <h2 class="section-title">Email</h2>
      <p class="muted mb-3">Current email: <strong><%= user.email %></strong></p>
      <form action="/settings/email/request-change" method="post" class="settings-form">
      <input type="hidden" name="_csrf" value="<%=csrfToken %>">
        <div class="form-group">
          <label for="newEmail">Change to new email</label>
          <input type="email" name="newEmail" id="newEmail" class="form-control" placeholder="new@example.com" required />
          <small class="form-hint">We’ll send a verification link to the new address. Your email updates after you confirm.</small>
        </div>
        <button type="submit" class="btn-primary">Send verification email</button>
      </form>
    </section>

    <!-- Linked accounts -->
    <section class="settings-section card">
      <h2 class="section-title">Linked accounts</h2>
      <p class="muted mb-3">Link Google or GitHub to sign in with them, or unlink if you no longer want to use them.</p>
      <div class="linked-providers">
        <div class="provider-row">
          <span class="provider-name">Google</span>
          <% if (user.googleId) { %>
            <span class="provider-badge linked">Linked</span>
            <form action="/settings/unlink/google" method="post" class="inline-form" onsubmit="return confirm('Unlink Google from this account?');">
            <input type="hidden" name="_csrf" value="<%=csrfToken %>">
              <button type="submit" class="btn-link danger">Unlink</button>
            </form>
          <% } else { %>
            <a href="/auth/google/link" class="btn-primary btn-sm text-white">Link Google</a>
          <% } %>
        </div>
        <div class="provider-row">
          <span class="provider-name">GitHub</span>
          <% if (user.githubId) { %>
            <span class="provider-badge linked">Linked</span>
            <form action="/settings/unlink/github" method="post" class="inline-form" onsubmit="return confirm('Unlink GitHub from this account?');">
            <input type="hidden" name="_csrf" value="<%=csrfToken %>">
              <button type="submit" class="btn-link danger">Unlink</button>
            </form>
          <% } else { %>
            <a href="/auth/github/link" class="btn-primary btn-sm text-white">Link GitHub</a>
          <% } %>
        </div>
      </div>
    </section>

    <!-- Password: OAuth users without a password see "Set password"; others see "Change password" -->
    <section class="settings-section card">
      <h2 class="section-title">Password</h2>
      <% const isOAuthOnly = (user.googleId || user.githubId) && user.hasPassword === false; %>
      <% if (isOAuthOnly) { %>
        <p class="muted mb-3">You signed up with Google or GitHub. Set a password to also sign in with email and password.</p>
        <form action="/settings/password/set" method="post" class="settings-form">
        <input type="hidden" name="_csrf" value="<%=csrfToken %>">
          <div class="form-group">
            <label for="setPassword">New password</label>
            <input type="password" name="password" id="setPassword" class="form-control" placeholder="••••••••" minlength="8" required />
          </div>
          <div class="form-group">
            <label for="setConfirmPassword">Confirm password</label>
            <input type="password" name="confirmPassword" id="setConfirmPassword" class="form-control" placeholder="••••••••" minlength="8" required />
          </div>
          <button type="submit" class="btn-primary">Set password</button>
        </form>
      <% } else { %>
        <!-- User has password (email signup or OAuth user who already set password) -->
        <p class="muted mb-3">Change your password. You’ll need to enter your current password.</p>
        <form action="/settings/password/change" method="post" class="settings-form">
        <input type="hidden" name="_csrf" value="<%=csrfToken %>">
          <div class="form-group">
            <label for="currentPassword">Current password</label>
            <input type="password" name="currentPassword" id="currentPassword" class="form-control" placeholder="••••••••" required />
          </div>
          <div class="form-group">
            <label for="newPassword">New password</label>
            <input type="password" name="password" id="newPassword" class="form-control" placeholder="••••••••" minlength="8" required />
          </div>
          <div class="form-group">
            <label for="confirmPassword">Confirm new password</label>
            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="••••••••" minlength="8" required />
          </div>
          <button type="submit" class="btn-primary">Change password</button>
        </form>
      <% } %>
    </section>

    <!-- Delete account -->
    <section class="settings-section card settings-danger">
      <h2 class="section-title">Close / Delete account</h2>
      <p class="muted mb-3">Permanently delete your account and all associated data. This cannot be undone.</p>
      <a href="/delete-account" class="btn-danger">Delete account</a>
    </section>
  </div>
</div>

<style>
.settings-page { max-width: 560px; margin: 48px auto; padding: 0 24px; }
.settings-container { display: flex; flex-direction: column; gap: 32px; }
.settings-title { margin-bottom: 4px; font-size: 1.75rem; }
.settings-subtitle { color: #6b7280; margin-bottom: 8px; }
.settings-section.card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 24px; }
.section-title { margin-bottom: 16px; font-size: 1.1rem; }
.settings-form .form-group { margin-bottom: 16px; }
.settings-form label { display: block; margin-bottom: 6px; font-size: 14px; }
.settings-form .form-control { width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; }
.settings-form .btn-primary { padding: 10px 18px; border-radius: 6px; border: none; background: #111827; color: #fff; font-weight: 500; cursor: pointer; }
.settings-form .btn-primary:hover { background: #000; }
.form-hint { display: block; margin-top: 6px; font-size: 12px; color: #6b7280; }
.avatar-group { margin-bottom: 12px; }
.settings-avatar { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; }
.mb-3 { margin-bottom: 12px; }
.settings-danger .btn-danger { display: inline-block; padding: 10px 18px; border-radius: 6px; background: #dc2626; color: #fff; text-decoration: none; font-weight: 500; border: none; cursor: pointer; }
.settings-danger .btn-danger:hover { background: #b91c1c; color: #fff; }
.linked-providers { display: flex; flex-direction: column; gap: 12px; }
.provider-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.provider-name { font-weight: 500; min-width: 80px; }
.provider-badge.linked { font-size: 12px; color: #16a34a; }
.inline-form { display: inline; margin: 0; }
.btn-link.danger { color: #dc2626; background: none; border: none; cursor: pointer; font-size: 14px; padding: 0; text-decoration: underline; }
.btn-link.danger:hover { color: #b91c1c; }
</style>
