<% layout('layout/boilerplate.ejs') %>

<div class="delete-account-page">
  <div class="delete-account-card card">
    <h2 class="mb-3">Delete account</h2>
    <% if (hasPassword) { %>
      <p class="muted mb-4">To permanently delete your account, enter your current password. This will remove all your apps and data.</p>
      <form action="/delete-account" method="post" class="settings-form">
      <input type="hidden" name="_csrf" value="<%=csrfToken %>">
        <div class="form-group">
          <label for="password">Your password</label>
          <input type="password" name="password" id="password" class="form-control" placeholder="••••••••" required autocomplete="current-password" />
        </div>
        <div class="form-actions">
          <a href="/settings" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-danger">Delete my account</button>
        </div>
      </form>
      <p class="mt-3 small muted">
        <a href="/forgot-password">Forgot your password?</a>
      </p>
    <% } else { %>
      <p class="muted mb-4">You signed in with Google or GitHub. Permanently delete your account and all your apps and data?</p>
      <form action="/delete-account" method="post" class="settings-form">
      <input type="hidden" name="_csrf" value="<%=csrfToken %>">
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="confirmDelete" value="yes" required />
            I understand this cannot be undone
          </label>
        </div>
        <div class="form-actions">
          <a href="/settings" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-danger">Delete my account</button>
        </div>
      </form>
    <% } %>
  </div>
</div>

<style>
.delete-account-page { max-width: 420px; margin: 48px auto; padding: 0 24px; }
.delete-account-card.card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 24px; }
.delete-account-card .form-group { margin-bottom: 16px; }
.delete-account-card label { display: block; margin-bottom: 6px; font-size: 14px; }
.delete-account-card .form-control { width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; }
.form-actions { display: flex; gap: 12px; margin-top: 16px; }
.btn-secondary { display: inline-block; padding: 10px 18px; border-radius: 6px; background: #f3f4f6; color: #374151; text-decoration: none; font-weight: 500; }
.btn-secondary:hover { background: #e5e7eb; color: #111; }
.delete-account-card .btn-danger { padding: 10px 18px; border-radius: 6px; border: none; background: #dc2626; color: #fff; font-weight: 500; cursor: pointer; }
.delete-account-card .btn-danger:hover { background: #b91c1c; }
.mb-3 { margin-bottom: 12px; }
.mb-4 { margin-bottom: 16px; }
.mt-3 { margin-top: 12px; }
.small { font-size: 13px; }
.muted { color: #6b7280; }
.checkbox-label { display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; }
.checkbox-label input { width: auto; }
</style>
